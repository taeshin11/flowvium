# Google Sheets webhook for silent analytics
NEXT_PUBLIC_SHEETS_WEBHOOK=

# Alpha Vantage API key (free tier: 25 req/day, 5/min)
# Used for live institutional ownership + news gap scores
# Get at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
NEXT_PUBLIC_ALPHA_VANTAGE_KEY=

# Upstash Redis — stores daily news gap scores (shared with MetaLens is fine, different keys)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron secret — protects /api/cron/update-signals from unauthorized calls
# Generate: openssl rand -hex 32
CRON_SECRET=

# Search engine webmaster verification codes
# Google: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing (also covers Yahoo Japan, DuckDuckGo): https://www.bing.com/webmasters
NEXT_PUBLIC_BING_SITE_VERIFICATION=
# Naver Search Advisor (Korea): https://searchadvisor.naver.com
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
# Baidu Webmaster (China): https://ziyuan.baidu.com
NEXT_PUBLIC_BAIDU_SITE_VERIFICATION=
# Yandex Webmaster (Russia): https://webmaster.yandex.com
NEXT_PUBLIC_YANDEX_VERIFICATION=
