{
  "name": "flowvium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "gen": "tsx scripts/generate-contexts.ts",
    "gen:single": "tsx scripts/generate-contexts.ts",
    "gen:skip": "SKIP_EXISTING=1 tsx scripts/generate-contexts.ts",
    "scrape": "tsx scripts/scrape-daily.ts",
    "scrape:sec": "tsx scripts/scrapers/sec-13f.ts",
    "scrape:macro": "tsx scripts/scrapers/fred-macro.ts",
    "scrape:news": "tsx scripts/scrapers/rss-news.ts",
    "scrape:gap": "tsx scripts/scrapers/news-gap-calc.ts",
    "check:hardcoded": "node scripts/check-hardcoded.mjs",
    "check:fallbacks": "node scripts/check-static-fallbacks.mjs",
    "verify": "node scripts/verify-all.mjs",
    "verify:report": "node scripts/verify-report.mjs",
    "verify:coverage": "node scripts/audit-coverage.mjs",
    "verify:company": "node scripts/audit-company-pages.mjs 30",
    "check:gitrisk": "node scripts/check-uncommitted-risk.mjs",
    "build:names": "node scripts/build-company-names.mjs",
    "build:universe": "node scripts/build-company-names.mjs && node scripts/build-universe-search.mjs",
    "setup:hooks": "bash scripts/install-hooks.sh",
    "check:timeframes": "node scripts/check-timeframes.mjs",
    "check:cron-sessions": "node scripts/check-cron-sessions.mjs",
    "db:backfill": "node scripts/backfill-db.mjs",
    "db:eval": "node scripts/evaluate-recommendations.mjs",
    "db:query": "node scripts/query-db.mjs",
    "review:logs": "node scripts/review-logs.mjs",
    "review:redis": "node scripts/review-logs.mjs --redis",
    "scan:satellite": "node scripts/satellite-factory-scan.mjs",
    "scan:satellite:dry": "node scripts/satellite-factory-scan.mjs --dry-run"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.1",
    "@google/generative-ai": "^0.24.1",
    "@types/d3": "^7.4.3",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "d3": "^7.9.0",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-intl": "^4.8.4",
    "react": "^18",
    "react-dom": "^18",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.8.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "better-sqlite3": "^12.9.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
